# Required for /api/draft-message — Live AI draft generation in the Performance AI Inbox.
# Get a key from https://console.anthropic.com/.
#
# Local dev: copy this file to `.env.local` and fill in the key.
#   (Note: /api routes only run under `vercel dev`, not plain `vite`.)
# Production: set ANTHROPIC_API_KEY in Vercel project settings → Environment Variables.
ANTHROPIC_API_KEY=
